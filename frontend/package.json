{
  "name": "calorie-track-mini-app",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 3000 --host 0.0.0.0",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "check": "tsc --noEmit && eslint . && prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "i18n:validate": "bun src/i18n/validate-keys.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "api:gen": "orval",
    "api:gen:watch": "orval --watch",
    "clean": "rm -rf dist node_modules/.vite"
  },
  "dependencies": {
    "@tanstack/react-query": "^5",
    "@telegram-apps/sdk": "^3",
    "@vercel/analytics": "^1",
    "@vercel/speed-insights": "^1",
    "i18next": "^25",
    "react": "^19",
    "react-day-picker": "^9",
    "react-dom": "^19",
    "react-i18next": "^16",
    "react-router-dom": "^7",
    "recharts": "^3",
    "swiper": "^12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4",
    "@eslint/js": "^10",
    "@playwright/test": "^1",
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "ajv": "^8.18.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-react-refresh": "^0.5",
    "globals": "^17",
    "jsdom": "^28",
    "msw": "^2",
    "orval": "^8",
    "playwright": "^1",
    "prettier": "^3",
    "tailwindcss": "^4",
    "typescript": "^5.9",
    "typescript-eslint": "^8",
    "vite": "^7",
    "vitest": "^4"
  }
}
